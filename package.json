{
  "name": "cristhion-portfolio",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "knip": "knip",
    "quality": "fallow --fail-on-issues",
    "check": "npm run lint && npm run test && npm run knip && npm run quality && npm run build"
  },
  "dependencies": {
    "vue": "^3.5.35"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@types/node": "^25.0.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "fallow": "^2.89.0",
    "jsdom": "^26.1.0",
    "knip": "^6.16.1",
    "typescript": "^5.9.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8",
    "vue-tsc": "^3.1.5"
  }
}
